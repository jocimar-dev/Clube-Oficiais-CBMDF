---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Not&iacute;cias | Clube dos Oficiais CBMDF">
  <Header />
  <div class="container breadcrumb-wrap">
    <nav class="breadcrumb" aria-label="Trilha de navegacao">
      <span>Voc&ecirc; est&aacute; aqui:</span>
      <a href="index.html">In&iacute;cio</a>
      <span>/</span>
      <span>Not&iacute;cias</span>
    </nav>
  </div>
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <h1 class="page-title">Not&iacute;cias</h1>
        <p class="page-subtitle">Comunicados institucionais, agenda e informativos do clube.</p>
        <div class="section-divider"></div>
        <div class="legacy-grid legacy-grid--2">
          <article class="legacy-card"><div class="legacy-card__head">Informativo - Edi&ccedil;&atilde;o 1</div><div class="legacy-card__body"><p>Primeira edi&ccedil;&atilde;o do informativo institucional disponibilizada em PDF.</p><p><a href="/docs/informativo-ed1-junho-2024.pdf" target="_blank" rel="noopener noreferrer">Abrir informativo (PDF)</a></p></div></article>
          <article class="legacy-card"><div class="legacy-card__head">Informativo - Edi&ccedil;&atilde;o 2</div><div class="legacy-card__body"><p>Edi&ccedil;&atilde;o complementar com a&ccedil;&otilde;es e comunicados para associados.</p><p><a href="/docs/informativo-numero2.pdf" target="_blank" rel="noopener noreferrer">Abrir informativo (PDF)</a></p></div></article>
          <article class="legacy-card"><div class="legacy-card__head">Informativo - Edi&ccedil;&atilde;o 3</div><div class="legacy-card__body"><p>Publica&ccedil;&atilde;o institucional com destaques de gest&atilde;o e atividades do clube.</p><p><a href="/docs/informativo-ed3-agosto-2025.pdf" target="_blank" rel="noopener noreferrer">Abrir informativo (PDF)</a></p></div></article>
          <article class="legacy-card"><div class="legacy-card__head">Institucional</div><div class="legacy-card__body"><p>Acesse as paginas institucionais com historia, diretoria e regulamentos.</p><p><a href="institucional.html">Acessar pagina institucional</a></p></div></article>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
