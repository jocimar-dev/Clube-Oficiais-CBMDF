---
import { getCollection, type CollectionEntry } from "astro:content";
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import NewsCard from "../components/NewsCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbs = [
  { label: "Inicio", href: "index.html" },
  { label: "Noticias" },
];

const news: CollectionEntry<"news">[] = (await getCollection("news")).sort(
  (a: CollectionEntry<"news">, b: CollectionEntry<"news">) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf(),
);
---

<BaseLayout
  title="Noticias"
  description="Informativos, comunicados institucionais e publicacoes recentes do Clube dos Oficiais CBMDF."
  breadcrumbs={breadcrumbs}
>
  <Header />
  <Breadcrumb items={breadcrumbs} />
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <SectionHeader
          title="Noticias"
          level="h1"
          subtitle="Comunicados institucionais, agenda e informativos do clube organizados por publicacao."
        />
        <div class="collection-toolbar" data-news-filters>
          <label class="collection-toolbar__search">
            <span class="is-hidden">Buscar noticia</span>
            <input type="search" placeholder="Buscar por titulo ou resumo" data-news-search />
          </label>
          <div class="collection-toolbar__chips" aria-label="Filtrar noticias por ano">
            <button type="button" class="is-active" data-news-filter="all">Todas</button>
            <button type="button" data-news-filter="2025">2025</button>
            <button type="button" data-news-filter="2024">2024</button>
          </div>
        </div>
        <div class="legacy-grid legacy-grid--2">
          {news.map((item: CollectionEntry<"news">) => <NewsCard entry={item} />)}
          <article class="legacy-card">
            <div class="legacy-card__head">Eventos e agenda</div>
            <div class="legacy-card__body">
              <p>Consulte registros de eventos, comunicados comemorativos e programacoes ja publicadas no portal.</p>
              <p><a href="eventos.html">Abrir pagina de eventos</a></p>
            </div>
          </article>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
