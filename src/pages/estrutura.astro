---
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbs = [
  { label: "Inicio", href: "index.html" },
  { label: "Estrutura" },
];
---

<BaseLayout
  title="Estrutura"
  description="Galeria institucional da estrutura do Clube dos Oficiais CBMDF com espacos de lazer, esporte e convivencia."
  breadcrumbs={breadcrumbs}
>
  <Header />
  <Breadcrumb items={breadcrumbs} />
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <SectionHeader
          title="Estrutura"
          level="h1"
          subtitle="Espacos de lazer, esporte e convivencia do Clube dos Oficiais CBMDF."
        />
        <div class="gallery-legacy__grid">
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Piscinas</h2>
            <figure class="gallery-legacy__media">
              <img src="images/piscina1.png" alt="Area principal de piscinas do clube" loading="lazy" />
              <figcaption>Espaco para lazer familiar.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Entrada</h2>
            <figure class="gallery-legacy__media">
              <img src="images/entrada-clube.jpg" alt="Entrada principal do clube" loading="lazy" />
              <figcaption>Acesso principal do complexo.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Eventos</h2>
            <figure class="gallery-legacy__media">
              <img src="images/eventos.png" alt="Area de eventos do clube" loading="lazy" />
              <figcaption>Estrutura para atividades sociais.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Campo</h2>
            <figure class="gallery-legacy__media">
              <img src="images/camp-futebol.png" alt="Campo esportivo do clube" loading="lazy" />
              <figcaption>Espaco para praticas esportivas.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Lazer aquatico</h2>
            <figure class="gallery-legacy__media">
              <img src="images/piscina01.png" alt="Piscina auxiliar e area de lazer" loading="lazy" />
              <figcaption>Ambiente para descanso e recreacao.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Area de lazer</h2>
            <figure class="gallery-legacy__media">
              <img src="images/area-lazer.png" alt="Area de lazer do clube" loading="lazy" />
              <figcaption>Convivencia para associados e familia.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Programacao cultural</h2>
            <figure class="gallery-legacy__media">
              <img src="images/show-forro.png" alt="Evento musical na estrutura do clube" loading="lazy" />
              <figcaption>Eventos culturais ao longo do ano.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Ambiente social</h2>
            <figure class="gallery-legacy__media">
              <img src="images/caderas-novas.jpg" alt="Ambiente social do clube com decoracao" loading="lazy" />
              <figcaption>Espacos preparados para encontros.</figcaption>
            </figure>
          </article>
          <article class="gallery-legacy__item">
            <h2 class="gallery-legacy__item-title">Piscina infantil</h2>
            <figure class="gallery-legacy__media">
              <img src="images/piscina0.png" alt="Piscina infantil do clube" loading="lazy" />
              <figcaption>Opcao recreativa para criancas.</figcaption>
            </figure>
          </article>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
