---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Benef&iacute;cios e Conv&ecirc;nios | Clube dos Oficiais CBMDF">
  <Header />
<div class="container breadcrumb-wrap">
  <nav class="breadcrumb" aria-label="Trilha de navegacao">
    <span>Voc&ecirc; est&aacute; aqui:</span>
    <a href="index.html">In&iacute;cio</a>
    <span>/</span>
    <span>Institucional</span>
    <span>/</span>
    <span>Benef&iacute;cios e Conv&ecirc;nios</span>
  </nav>
</div>
<main class="main-content">
  <div class="container">
    <section class="page-section">
      <h1 class="page-title">Benef&iacute;cios e Conv&ecirc;nios</h1>
      <p class="page-subtitle">Conteudo consolidado de beneficios e convenios institucionais.</p>
      <div class="section-divider"></div>
      <div class="legacy-grid legacy-grid--2">
        <article class="legacy-card"><div class="legacy-card__head">Beneficios</div><div class="legacy-card__body"><p>Acesso a eventos, programacao social, agenda esportiva e servicos para associados.</p></div></article>
        <article class="legacy-card"><div class="legacy-card__head">Convenios</div><div class="legacy-card__body"><p>Parcerias em saude, educacao e bem-estar para socios e dependentes.</p><ul><li>Clinica Essencial</li><li>Academia Vital</li><li>Universidade Leste</li><li>Colegio Horizonte Azul</li></ul></div></article>
      </div>
    </section>
  </div>
</main>
  <Footer />
</BaseLayout>

