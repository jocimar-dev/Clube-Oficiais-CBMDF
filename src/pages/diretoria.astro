---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Diretoria | Clube dos Oficiais CBMDF">
  <Header />
  <div class="container breadcrumb-wrap">
    <nav class="breadcrumb" aria-label="Trilha de navegacao">
      <span>Voc&ecirc; est&aacute; aqui:</span>
      <a href="index.html">In&iacute;cio</a>
      <span>/</span>
      <span>Institucional</span>
      <span>/</span>
      <span>Diretoria</span>
    </nav>
  </div>
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <h1 class="page-title">Diretoria</h1>
        <p class="page-subtitle">Gest&atilde;o COCBMDF 2026/2027.</p>
        <div class="section-divider"></div>
        <div class="legacy-table-stack">
          <div class="legacy-table-wrap legacy-table-wrap--board">
            <div class="legacy-table-title">Diretoria Executiva</div>
            <table class="legacy-table legacy-table--board">
              <thead><tr><th>Cargo</th><th>Nome Completo</th><th>Posto</th></tr></thead>
              <tbody>
                <tr><td>Presidente</td><td>WELLLINGTON MOURA E SILVA</td><td>CEL</td></tr>
                <tr><td>Vice-presidente</td><td>MAURO SERGIO SILVA COSTA</td><td>CAP</td></tr>
                <tr><td>1&deg; Tesoureiro</td><td>MAURO ANDRE KAISER CABRAL</td><td>TC</td></tr>
                <tr><td>2&deg; Tesoureiro</td><td>ANTONIO CLEMENTE DE OLIVEIRA</td><td>CAP</td></tr>
                <tr><td>1&deg; Secret&aacute;rio</td><td>ATILA GOMES NASCIMENTO</td><td>CEL</td></tr>
                <tr><td>2&deg; Secret&aacute;rio</td><td>VITOR HENRIQUE DA CUNHA MARIANO</td><td>MAJ</td></tr>
                <tr><td>Diretor S&oacute;cio Cultural</td><td>LUCIANO DE ARAUJO GALENO JUNIOR</td><td>CAP</td></tr>
                <tr><td>Diretor de Lazer e Atividades Desportivas</td><td>GUILHERME ROCHA FARIA</td><td>CAP</td></tr>
                <tr><td>Diretor Administrativo e Patrim&ocirc;nio</td><td>JEAN CARLOS DE SOUZA RIBEIRO</td><td>MAJ</td></tr>
                <tr><td>Diretor de Comunica&ccedil;&atilde;o Social</td><td>OCTAVIO AUGUSTO QUINTILIANO</td><td>CAP</td></tr>
              </tbody>
            </table>
          </div>
          <div class="legacy-table-wrap legacy-table-wrap--board">
            <div class="legacy-table-title">Conselho Deliberativo</div>
            <table class="legacy-table legacy-table--board">
              <thead><tr><th>Cargo</th><th>Nome Completo</th><th>Posto</th></tr></thead>
              <tbody>
                <tr><td>Presidente</td><td>SILVERIO FREIRE DE CARVALHO FILHO</td><td>CEL</td></tr>
                <tr><td>Vice-presidente</td><td>ARISTIDES ALMEIDA NETO</td><td>TC</td></tr>
                <tr><td>1&deg; Conselheiro</td><td>PAULO ROBERTO</td><td>TC</td></tr>
                <tr><td>2&deg; Conselheiro</td><td>FABIO MOREIRA SILVA</td><td>TC</td></tr>
                <tr><td>1&deg; Suplente</td><td>ALFREDO JOSE DOS SANTOS NETO</td><td>MAJ</td></tr>
              </tbody>
            </table>
          </div>
          <div class="legacy-table-wrap legacy-table-wrap--board">
            <div class="legacy-table-title">Conselho Fiscal</div>
            <table class="legacy-table legacy-table--board">
              <thead><tr><th>Cargo</th><th>Nome Completo</th><th>Posto</th></tr></thead>
              <tbody>
                <tr><td>Presidente</td><td>ENZO PEREIRA TEIXEIRA</td><td>TC</td></tr>
                <tr><td>Vice-presidente</td><td>MAX WERNER MAIA BANDEIRA</td><td>TC</td></tr>
                <tr><td>1&deg; Vogal</td><td>KLEBER FRANCISCO DE OLIVEIRA CORREIA</td><td>CEL</td></tr>
                <tr><td>2&deg; Vogal</td><td>ELIANE VIEIRA DE ASSIS</td><td>TC</td></tr>
                <tr><td>1&deg; Suplente</td><td>LEONARDO FARIA DE OLIVEIRA</td><td>MAJ</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
