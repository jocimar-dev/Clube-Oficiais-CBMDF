---
import { getCollection, type CollectionEntry } from "astro:content";
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import LeadershipTable from "../components/LeadershipTable.astro";
import SectionHeader from "../components/SectionHeader.astro";
import TrustStats from "../components/TrustStats.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbs = [
  { label: "Inicio", href: "index.html" },
  { label: "Diretoria" },
];

const leadership: CollectionEntry<"leadership">[] = (await getCollection("leadership")).sort(
  (a: CollectionEntry<"leadership">, b: CollectionEntry<"leadership">) => a.data.order - b.data.order,
);
const executiveBoard: CollectionEntry<"leadership">[] = leadership.filter(
  (entry: CollectionEntry<"leadership">) => entry.data.board === "diretoria-executiva",
);
const deliberativeBoard: CollectionEntry<"leadership">[] = leadership.filter(
  (entry: CollectionEntry<"leadership">) => entry.data.board === "conselho-deliberativo",
);
const fiscalBoard: CollectionEntry<"leadership">[] = leadership.filter(
  (entry: CollectionEntry<"leadership">) => entry.data.board === "conselho-fiscal",
);

const boardStats = [
  { value: "2026/2027", label: "Mandato publicado", note: "Gestao vigente apresentada no portal." },
  { value: `${executiveBoard.length}`, label: "Integrantes na diretoria executiva" },
  { value: `${deliberativeBoard.length}`, label: "Integrantes no conselho deliberativo" },
  { value: `${fiscalBoard.length}`, label: "Integrantes no conselho fiscal" },
];
---

<BaseLayout
  title="Diretoria"
  description="Gestao COCBMDF 2026/2027 com diretoria executiva, conselho deliberativo e conselho fiscal."
  breadcrumbs={breadcrumbs}
>
  <Header />
  <Breadcrumb items={breadcrumbs} />
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <SectionHeader
          title="Diretoria"
          level="h1"
          subtitle="Gestao COCBMDF 2026/2027 com organizacao colegiada, cargos executivos e governanca institucional."
        />
        <div class="legacy-split diretoria-page__intro">
          <div>
            <p>
              A estrutura de governanca do clube esta organizada em diretoria executiva, conselho deliberativo e
              conselho fiscal, com definicao publica de cargos, nomes e postos.
            </p>
            <p class="page-copy-spaced">
              A apresentacao abaixo reforca a autoridade institucional e facilita a consulta por associados,
              convidados e interessados em acompanhar a gestao vigente.
            </p>
          </div>
          <TrustStats items={boardStats} className="trust-stats--compact" />
        </div>
        <div class="legacy-table-stack">
          <LeadershipTable
            title="Diretoria Executiva"
            description="Responsavel pela conducao administrativa, financeira, social e operacional da gestao."
            members={executiveBoard}
          />
          <LeadershipTable
            title="Conselho Deliberativo"
            description="Colegiado de apoio institucional e deliberacao das pautas regimentais."
            members={deliberativeBoard}
          />
          <LeadershipTable
            title="Conselho Fiscal"
            description="Colegiado destinado ao acompanhamento e a fiscalizacao dos controles institucionais."
            members={fiscalBoard}
          />
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
