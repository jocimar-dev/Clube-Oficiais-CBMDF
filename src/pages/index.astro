---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Home | Clube dos Oficiais CBMDF">
  <Header />
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <h2 class="page-title"><a class="page-title-link" href="estrutura.html">Nossa Estrutura</a></h2>
        <p class="page-subtitle">Destaques de estrutura, lazer e programacao social do clube.</p>
        <div class="legacy-banner" data-banner-slider>
          <div class="legacy-banner__viewport">
            <article class="legacy-banner__slide is-active" data-banner-slide><img src="images/entrada-clube.jpg" alt="Entrada principal do Clube dos Oficiais CBMDF" loading="lazy" /><p class="legacy-banner__caption">Entrada principal e acesso ao complexo social do clube.</p></article>
            <article class="legacy-banner__slide" data-banner-slide><img src="images/banner-salao-social.jpg" alt="Area de churrasqueiras e espaco coberto do clube" loading="lazy" /><p class="legacy-banner__caption">Churrasqueiras e espa&ccedil;o coberto para confraterniza&ccedil;&atilde;o dos associados.</p></article>
            <article class="legacy-banner__slide" data-banner-slide><img class="legacy-banner__img--field" src="images/banner-campo-futebol-v3.jpg" alt="Campo de futebol do Clube dos Oficiais CBMDF" loading="lazy" /><p class="legacy-banner__caption">Campo de futebol para atividades esportivas e recreativas dos associados.</p></article>
            <article class="legacy-banner__slide" data-banner-slide><img class="legacy-banner__img--lower" src="images/banner-piscina.jpg" alt="Piscina do Clube dos Oficiais CBMDF" loading="lazy" /><p class="legacy-banner__caption">Piscina social e area de descanso para lazer da familia bombeiro militar.</p></article>
            <article class="legacy-banner__slide" data-banner-slide><img src="images/banner-area-verde.jpg" alt="Area de convivio e lazer do clube" loading="lazy" /><p class="legacy-banner__caption">Ambiente de conviv&ecirc;ncia e lazer para integra&ccedil;&atilde;o da fam&iacute;lia bombeiro militar.</p></article>
          </div>
          <div class="legacy-banner__dots" aria-label="Controle do banner">
            <button type="button" data-banner-dot class="is-active" aria-label="Banner 1" aria-pressed="true"></button>
            <button type="button" data-banner-dot aria-label="Banner 2" aria-pressed="false"></button>
            <button type="button" data-banner-dot aria-label="Banner 3" aria-pressed="false"></button>
            <button type="button" data-banner-dot aria-label="Banner 4" aria-pressed="false"></button>
            <button type="button" data-banner-dot aria-label="Banner 5" aria-pressed="false"></button>
          </div>
        </div>
      </section>
      <section class="page-section home-hero">
        <div class="home-hero__content">
          <p class="home-hero__kicker">Clube dos Oficiais CBMDF</p>
          <h1 class="page-title">Portal Institucional do Clube dos Oficiais do CBMDF</h1>
          <p class="page-subtitle">Clube dos Oficiais do Corpo de Bombeiros Militar do Distrito Federal.</p>
          <div class="info-banner">Espa&ccedil;o institucional para esporte, lazer e atividades sociais dos associados.</div>
          <ul class="home-hero__bullets">
            <li>Ambiente familiar e seguro</li>
            <li>Programa&ccedil;&atilde;o social durante o ano</li>
            <li>Estrutura para atividades esportivas</li>
          </ul>
          <div class="home-hero__actions">
            <a class="legacy-doc__button" href="associe-se.html">Quero me associar</a>
            <a class="legacy-doc__button" href="diretoria.html">Ver Diretoria 2026/2027</a>
          </div>
        </div>
        <aside class="home-hero__aside">
          <figure class="home-hero__media">
            <img src="images/entrada-clube.jpg" alt="Entrada do Clube dos Oficiais CBMDF" loading="lazy" />
            <figcaption>Patrim&ocirc;nio institucional da oficialidade bombeiro militar.</figcaption>
          </figure>
          <article class="legacy-card home-fire-card">
            <div class="legacy-card__head">Esp&iacute;rito de Corpora&ccedil;&atilde;o</div>
            <div class="legacy-card__body">
              <p>Compromisso com unidade, respeito e valoriza&ccedil;&atilde;o da nossa hist&oacute;ria institucional.</p>
            </div>
          </article>
        </aside>
      </section>
      <section class="page-section home-events">
        <h2 class="page-title">Eventos</h2>
        <p class="page-subtitle">Agenda de atividades sociais e comemorativas do clube.</p>
        <div class="section-divider"></div>
        <div class="legacy-grid legacy-grid--4 home-events__grid">
          <article class="legacy-card home-events__card">
            <div class="legacy-card__head">Dia do Bombeiro Militar</div>
            <div class="home-events__media"><img src="images/evento-dia-bombeiro.png" alt="Arte do evento Dia do Bombeiro Militar" loading="lazy" /></div>
            <div class="legacy-card__body"><p>Comemoracao institucional em homenagem aos soldados do fogo.</p></div>
          </article>
          <article class="legacy-card home-events__card">
            <div class="legacy-card__head">Dia das Crian&ccedil;as</div>
            <div class="home-events__media"><img src="images/evento-dia-criancas.png" alt="Arte do evento Dia das Criancas" loading="lazy" /></div>
            <div class="legacy-card__body"><p>Programacao infantil com brincadeiras e atividades para toda a familia.</p></div>
          </article>
          <article class="legacy-card home-events__card">
            <div class="legacy-card__head">Esse Forr&oacute; &eacute; Nosso</div>
            <div class="home-events__media"><img src="images/evento-forro-nosso.png" alt="Arte do evento musical Esse Forro e Nosso" loading="lazy" /></div>
            <div class="legacy-card__body"><p>Noite musical com atracoes culturais e convivencia social dos associados.</p></div>
          </article>
          <article class="legacy-card home-events__card">
            <div class="legacy-card__head">Oficiais Promovidos</div>
            <div class="home-events__media"><img src="images/evento-parabeniza-oficiais.png" alt="Arte institucional parabenizando oficiais promovidos" loading="lazy" /></div>
            <div class="legacy-card__body"><p>Mensagem institucional em reconhecimento aos oficiais promovidos.</p></div>
          </article>
        </div>
      </section>
      <section class="page-section home-services">
        <h2 class="page-title">Servi&ccedil;os do Associado</h2>
        <p class="page-subtitle">Acesso r&aacute;pido aos principais servi&ccedil;os e informa&ccedil;&otilde;es do clube.</p>
        <div class="section-divider"></div>
        <div class="legacy-grid legacy-grid--3 home-services__grid">
          <article class="legacy-card home-services__card"><div class="legacy-card__head">Associe-se</div><div class="legacy-card__body"><p>Formularios e orientacoes para ingresso no quadro de associados.</p><p><a href="associe-se.html">Acessar pagina</a></p></div></article>
          <article class="legacy-card home-services__card"><div class="legacy-card__head">Diretoria</div><div class="legacy-card__body"><p>Composicao oficial da gestao COCBMDF 2026/2027.</p><p><a href="diretoria.html">Acessar pagina</a></p></div></article>
          <article class="legacy-card home-services__card"><div class="legacy-card__head">Informativos</div><div class="legacy-card__body"><p>Publicacoes institucionais e comunicados do clube.</p><p><a href="noticias.html">Acessar pagina</a></p></div></article>
          <article class="legacy-card home-services__card"><div class="legacy-card__head">Beneficios e Convenios</div><div class="legacy-card__body"><p>Parcerias e vantagens para associados e dependentes.</p><p><a href="conheca-clube.html">Acessar pagina</a></p></div></article>
          <article class="legacy-card home-services__card"><div class="legacy-card__head">Horarios</div><div class="legacy-card__body"><p>Funcionamento do clube e atendimento da secretaria.</p><p><a href="horarios.html">Acessar pagina</a></p></div></article>
          <article class="legacy-card home-services__card"><div class="legacy-card__head">Contatos</div><div class="legacy-card__body"><p>Telefone, WhatsApp e canais institucionais oficiais.</p><p><a href="contatos.html">Acessar pagina</a></p></div></article>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
