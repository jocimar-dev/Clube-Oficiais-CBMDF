---
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbs = [
  { label: "Inicio", href: "index.html" },
  { label: "Institucional", href: "institucional.html" },
  { label: "Historia" },
];

const timeline = [
  {
    period: "1989",
    title: "Fundacao institucional",
    description:
      "O clube foi criado em 02 de dezembro de 1989, consolidando um espaco de integracao para a oficialidade bombeiro militar.",
  },
  {
    period: "1991 a 1999",
    title: "Primeiras gestoes registradas",
    description:
      "A fase inicial de presidencias estruturou a base institucional e fortaleceu a presenca do clube junto aos associados.",
  },
  {
    period: "2000 a 2017",
    title: "Consolidacao administrativa",
    description:
      "A sucessao de gestoes ampliou a organizacao interna, os servicos e a agenda de convivencia social e esportiva.",
  },
  {
    period: "2018 a 2027",
    title: "Atualizacao de governanca e portal",
    description:
      "O ciclo recente reforca a publicacao institucional, a apresentacao da diretoria e a organizacao digital de documentos e informativos.",
  },
];
---

<BaseLayout
  title="Historia"
  description="Historia do Clube dos Oficiais CBMDF com linha do tempo institucional e registro de presidencias."
  breadcrumbs={breadcrumbs}
>
  <Header />
  <Breadcrumb items={breadcrumbs} />
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <SectionHeader
          title="Historia do Clube"
          level="h1"
          subtitle="Linha do tempo institucional, marco de fundacao e registro de presidencias historicas."
        />
        <div class="history-timeline">
          {timeline.map((item) => (
            <article class="history-timeline__item">
              <p class="history-timeline__period">{item.period}</p>
              <div class="history-timeline__content">
                <h2>{item.title}</h2>
                <p>{item.description}</p>
              </div>
            </article>
          ))}
        </div>
        <div class="legacy-table-wrap history-table">
          <div class="legacy-table-title">Presidentes do Clube (historico)</div>
          <table class="legacy-table">
            <thead>
              <tr>
                <th>Posto</th>
                <th>Nome</th>
                <th>Ano</th>
              </tr>
            </thead>
            <tbody>
              <tr><td>TC QOBM/Comb.</td><td>Luiz Carlos Serafim Silva</td><td>1991 a 1991</td></tr>
              <tr><td>TC QOBM/Comb.</td><td>Benjamim Ferreira Bispo</td><td>1992 a 1997</td></tr>
              <tr><td>CEL QOBM/Comb.</td><td>Jose Carlos Pereira Duarte</td><td>1998 a 1999</td></tr>
              <tr><td>CEL QOBM/Comb.</td><td>Milton Antonio Paduan</td><td>2000 a 2001</td></tr>
              <tr><td>CEL QOBM/Comb.</td><td>Renato Ferreira Guimaraes</td><td>2002 a 2005</td></tr>
              <tr><td>CEL QOBM/Comb.</td><td>Evaldo Marques Rabelo</td><td>2006 a 2007</td></tr>
              <tr><td>CEL QOBM/Comb.</td><td>Edilson Bezerra de Oliveira</td><td>2008 a 2009</td></tr>
              <tr><td>TC QOBM/Comb.</td><td>Paulo Arthur Santa Cruz dos Santos</td><td>2010 a 2013</td></tr>
              <tr><td>CEL QOBM/Comb.</td><td>Edwin Aldrin Franco de Oliveira</td><td>2014 a 2017</td></tr>
              <tr><td>CEL QOBM/Comb.</td><td>Valdir Luiz Ferrari Junior</td><td>2018 a 2019</td></tr>
            </tbody>
          </table>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
