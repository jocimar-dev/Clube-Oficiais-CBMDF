---
import { getCollection, type CollectionEntry } from "astro:content";
import Breadcrumb from "../../components/Breadcrumb.astro";
import CTAGroup from "../../components/CTAGroup.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { contact } from "../../data/site";
import { eventStatusLabel, formatFullDate } from "../../data/content-utils";

export async function getStaticPaths() {
  const events = await getCollection("events");

  return events.map((entry: CollectionEntry<"events">) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"events">;
}

const { entry } = Astro.props;

const breadcrumbs = [
  { label: "Inicio", href: "/index.html" },
  { label: "Eventos", href: "/eventos.html" },
  { label: entry.data.title },
];

const eventSchema = {
  "@context": "https://schema.org",
  "@type": "Event",
  name: entry.data.title,
  startDate: entry.data.startDate.toISOString(),
  eventAttendanceMode: "https://schema.org/OfflineEventAttendanceMode",
  eventStatus: "https://schema.org/EventScheduled",
  image: [`https://clubedosoficiaiscbmdf.com.br${entry.data.cover}`],
  location: {
    "@type": "Place",
    name: entry.data.location,
    address: "St. de Clubes Esportivos Sul Trecho 2 - Asa Sul, Brasilia - DF, 70297-400",
  },
  description: entry.data.summary,
};
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.summary}
  breadcrumbs={breadcrumbs}
  ogImage={entry.data.cover}
  schema={eventSchema}
>
  <Header />
  <Breadcrumb items={breadcrumbs} />
  <main class="main-content">
    <div class="container">
      <section class="page-section event-detail">
        <SectionHeader title={entry.data.title} level="h1" subtitle={entry.data.summary} />
        <div class="legacy-split event-detail__hero">
          <figure class="event-detail__media">
            <img src={entry.data.cover} alt={entry.data.title} loading="eager" />
            <figcaption>Registro institucional publicado no portal do clube.</figcaption>
          </figure>
          <article class="legacy-card">
            <div class="legacy-card__head">Informacoes do evento</div>
            <div class="legacy-card__body">
              <p><strong>Data:</strong> {formatFullDate(entry.data.startDate)}</p>
              {entry.data.time && <p><strong>Horario:</strong> {entry.data.time}</p>}
              <p><strong>Local:</strong> {entry.data.location}</p>
              <p><strong>Status:</strong> {eventStatusLabel(entry)}</p>
            </div>
          </article>
        </div>

        <div class="legacy-split event-detail__content">
          <article class="legacy-highlight">
            <div class="legacy-highlight__title">Destaques publicados</div>
            <ul class="legacy-line-list legacy-line-list--compact">
              {entry.data.highlights.map((highlight: string) => <li>{highlight}</li>)}
            </ul>
          </article>
          <article class="legacy-card">
            <div class="legacy-card__head">Atendimento institucional</div>
            <div class="legacy-card__body">
              <p>Confirmacoes de agenda, orientacoes ao associado e informacoes complementares podem ser obtidas com a secretaria.</p>
              <div class="event-detail__actions">
                <CTAGroup
                  primary={{ href: contact.whatsappHref, label: "Falar com a secretaria" }}
                  secondary={{ href: "/eventos.html", label: "Voltar para eventos" }}
                />
              </div>
            </div>
          </article>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
