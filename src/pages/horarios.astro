---
import Breadcrumb from "../components/Breadcrumb.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbs = [
  { label: "Inicio", href: "index.html" },
  { label: "Institucional", href: "institucional.html" },
  { label: "Horarios de funcionamento" },
];
---

<BaseLayout
  title="Horarios"
  description="Horarios de funcionamento do clube e da secretaria do Clube dos Oficiais CBMDF."
  breadcrumbs={breadcrumbs}
>
  <Header />
  <Breadcrumb items={breadcrumbs} />
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <SectionHeader
          title="Horario de funcionamento do clube"
          level="h1"
          subtitle="Referencia institucional para funcionamento do clube e atendimento da secretaria."
        />
        <ul class="legacy-line-list">
          <li>Terca a sexta: de 09h as 17h.</li>
          <li>Sabado, domingo e feriados: de 09h as 18h.</li>
        </ul>
        <SectionHeader
          title="Horario de funcionamento da secretaria"
          subtitle="Atendimento administrativo para orientacoes, associacao e informacoes do clube."
          className="section-header--compact"
        />
        <ul class="legacy-line-list">
          <li>Terca a sabado: de 09h as 17h.</li>
          <li>Domingo e feriados: fechado.</li>
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
