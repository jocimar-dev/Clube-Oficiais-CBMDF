---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Localiza&ccedil;&atilde;o | Clube dos Oficiais CBMDF">
  <Header />
<div class="container breadcrumb-wrap">
  <nav class="breadcrumb" aria-label="Trilha de navegacao">
    <span>Voc&ecirc; est&aacute; aqui:</span>
    <a href="index.html">In&iacute;cio</a>
    <span>/</span>
    <span>Localiza&ccedil;&atilde;o</span>
  </nav>
</div>
<main class="main-content">
  <div class="container">
    <section class="page-section">
      <h1 class="page-title">Localiza&ccedil;&atilde;o</h1>
      <p class="page-subtitle">Informacoes de acesso ao Clube dos Oficiais do CBMDF.</p>
      <div class="section-divider"></div>
      <div class="legacy-split">
        <div>
          <h2 class="page-title" style="font-size:1.8rem;">Endere&ccedil;o</h2>
          <p>COCBM-DF</p><p>SCES Trecho 2 Lote 02/35</p><p>CEP: 70200-002 - Brasilia, DF</p>
          <p style="margin-top:12px;">Referencias: regiao de clubes do Lago Sul, com acesso por vias principais da cidade.</p>
          <h2 class="page-title" style="font-size:1.8rem; margin-top:20px;">Acesso</h2>
          <ul class="legacy-line-list">
            <li>Entrada principal com identificacao de associados.</li>
            <li>Estacionamento interno para visitantes autorizados.</li>
            <li>Atendimento na secretaria durante horario administrativo.</li>
          </ul>
        </div>
        <div class="placeholder-map"><p>Mapa do clube (placeholder visual)</p><p>Integracao com mapa real pode ser adicionada depois.</p></div>
      </div>
    </section>
  </div>
</main>
  <Footer />
</BaseLayout>

