---
import Breadcrumb from "../components/Breadcrumb.astro";
import CTAGroup from "../components/CTAGroup.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SectionHeader from "../components/SectionHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { contact } from "../data/site";

const breadcrumbs = [
  { label: "Inicio", href: "index.html" },
  { label: "Localizacao" },
];

const locationSchema = {
  "@context": "https://schema.org",
  "@type": "SportsActivityLocation",
  name: "Clube dos Oficiais do Corpo de Bombeiros Militar do Distrito Federal",
  address: {
    "@type": "PostalAddress",
    streetAddress: "St. de Clubes Esportivos Sul Trecho 2 - Asa Sul",
    addressLocality: "Brasilia",
    addressRegion: "DF",
    postalCode: "70297-400",
    addressCountry: "BR",
  },
  telephone: "+55-61-3224-6041",
};
---

<BaseLayout
  title="Localizacao"
  description="Endereco oficial, referencias de acesso e mapa do Clube dos Oficiais CBMDF em Brasilia."
  breadcrumbs={breadcrumbs}
  schema={locationSchema}
>
  <Header />
  <Breadcrumb items={breadcrumbs} />
  <main class="main-content">
    <div class="container">
      <section class="page-section">
        <SectionHeader
          title="Localizacao"
          level="h1"
          subtitle="Endereco oficial, referencias de acesso e navegacao por mapa do Clube dos Oficiais CBMDF."
        />
        <div class="legacy-split location-page">
          <div>
            <h2 class="section-subtitle">Endereco</h2>
            <p>COCBM-DF</p>
            <p>{contact.addressLine1}</p>
            <p>{contact.addressLine2}</p>
            <p class="page-copy-spaced">
              Referencia: regiao de clubes do Lago Sul, com acesso pelas vias principais do Distrito Federal.
            </p>
            <h2 class="section-subtitle section-subtitle--spaced">Acesso</h2>
            <ul class="legacy-line-list">
              <li>Entrada principal com identificacao de associados e visitantes autorizados.</li>
              <li>Estacionamento interno para atendimento e programacao do clube.</li>
              <li>Secretaria em funcionamento durante o horario administrativo publicado no portal.</li>
            </ul>
            <div class="location-page__actions">
              <CTAGroup
                primary={{
                  href: "https://www.google.com/maps/place/Clube+dos+Oficiais+do+CBMDF+-+COCBMDF/@-15.8166955,-47.843356,17z/data=!3m1!4b1!4m6!3m5!1s0x935a235790b04937:0x261e59d8480bb881!8m2!3d-15.8167007!4d-47.8407811!16s%2Fg%2F11b6hnh42q?entry=ttu&g_ep=EgoyMDI2MDMxMS4wIKXMDSoASAFQAw%3D%3D",
                  label: "Abrir no mapa",
                }}
              />
            </div>
          </div>
          <div class="location-map">
            <iframe
              title="Mapa do Clube dos Oficiais CBMDF"
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3838.758262596431!2d-47.84335602569436!3d-15.816695523502945!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x935a235790b04937%3A0x261e59d8480bb881!2sClube%20dos%20Oficiais%20do%20CBMDF%20-%20COCBMDF!5e0!3m2!1spt-BR!2sbr!4v1773453650414!5m2!1spt-BR!2sbr"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
            ></iframe>
          </div>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
