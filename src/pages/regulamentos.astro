---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Regulamentos | Clube dos Oficiais CBMDF">
  <Header />
<div class="container breadcrumb-wrap">
  <nav class="breadcrumb" aria-label="Trilha de navegacao">
    <span>Voc&ecirc; est&aacute; aqui:</span>
    <a href="index.html">In&iacute;cio</a>
    <span>/</span>
    <span>Institucional</span>
    <span>/</span>
    <span>Regulamentos</span>
  </nav>
</div>
<main class="main-content">
  <div class="container">
    <section class="page-section">
      <h1 class="page-title">Regulamentos</h1>
      <div class="section-divider"></div>
      <div class="legacy-grid legacy-grid--3">
        <article class="legacy-card"><div class="legacy-card__head">Estatuto do Clube</div><div class="legacy-card__body"><p>Estatuto do Clube dos Oficiais do CBMDF.</p><p><a href="#">Visualizar documento</a></p></div></article>
        <article class="legacy-card"><div class="legacy-card__head">Normas de Acesso ao Clube</div><div class="legacy-card__body"><p>Regulamento n&ordm; 01/2015 - Normas de acesso ao clube.</p><p><a href="#">Visualizar documento</a></p></div></article>
        <article class="legacy-card"><div class="legacy-card__head">Utiliza&ccedil;&atilde;o das Churrasqueiras</div><div class="legacy-card__body"><p>Regulamento n&ordm; 02/2015 e 03/2015 - uso e condicoes das churrasqueiras.</p><p><a href="#">Visualizar documento</a></p></div></article>
      </div>
      <div class="legacy-table-wrap" style="margin-top:20px;">
        <div class="legacy-table-title">Documentos Institucionais Complementares</div>
        <table class="legacy-table">
          <thead><tr><th>Documento</th><th>Tipo</th><th>Status</th></tr></thead>
          <tbody><tr><td>Edital de Convocacao</td><td>Assembleia</td><td>Disponivel</td></tr><tr><td>Ata da Ultima Reuniao</td><td>Registro</td><td>Disponivel</td></tr><tr><td>Regimento Interno</td><td>Normativo</td><td>Disponivel</td></tr></tbody>
        </table>
      </div>
    </section>
  </div>
</main>
  <Footer />
</BaseLayout>

