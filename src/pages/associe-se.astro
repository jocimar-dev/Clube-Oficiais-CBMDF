---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Associe-se | Clube dos Oficiais CBMDF">
  <Header />
<div class="container breadcrumb-wrap">
  <nav class="breadcrumb" aria-label="Trilha de navegacao">
    <span>Voc&ecirc; est&aacute; aqui:</span>
    <a href="index.html">In&iacute;cio</a>
    <span>/</span>
    <span>Associe-se</span>
  </nav>
</div>
<main class="main-content">
  <div class="container">
    <section class="page-section">
      <h1 class="page-title">Associe-se</h1>
      <div class="section-divider"></div>
      <div class="legacy-doc-grid">
        <article class="legacy-doc"><div class="legacy-doc__title">Ficha de Cadastro - Titular</div><div class="legacy-doc__body"><p>Documento base para cadastro de novos associados.</p><div class="legacy-doc__actions"><a class="legacy-doc__button" href="#">Baixar arquivo</a></div></div></article>
        <article class="legacy-doc"><div class="legacy-doc__title">Requerimento de Ades&atilde;o - S&oacute;cio</div><div class="legacy-doc__body"><p>Formulario de adesao para ingresso no quadro de associados.</p><div class="legacy-doc__actions"><a class="legacy-doc__button" href="#">Baixar arquivo</a></div></div></article>
        <article class="legacy-doc"><div class="legacy-doc__title">Checklist de Documentos</div><div class="legacy-doc__body"><p>Lista de documentos pessoais e comprovacoes para validacao da adesao.</p><div class="legacy-doc__actions"><a class="legacy-doc__button" href="#">Consultar lista</a></div></div></article>
      </div>
      <h2 class="page-title" style="margin-top:24px;">Fluxo de associa&ccedil;&atilde;o</h2>
      <ul class="legacy-line-list">
        <li>Preenchimento da ficha e requerimento.</li>
        <li>Entrega dos documentos na secretaria.</li>
        <li>Analise e confirmacao de cadastro pela diretoria.</li>
      </ul>
    </section>
  </div>
</main>
  <Footer />
</BaseLayout>

