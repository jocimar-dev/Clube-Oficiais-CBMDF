---
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  className?: string;
}

const { items, className = "" } = Astro.props;
---

<div class:list={["faq-list", className]}>
  {items.map((item: FaqItem) => (
    <article class="legacy-card faq-card">
      <div class="legacy-card__body">
        <h3 class="faq-card__question">{item.question}</h3>
        <p class="faq-card__answer">{item.answer}</p>
      </div>
    </article>
  ))}
</div>
